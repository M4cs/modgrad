{
  "name": "modgrad",
  "version": "0.1.3",
  "description": "Beautiful, optionally animated mesh / blurry / grainy gradient backgrounds for React.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "license": "MIT",
  "author": "Max Bridgland <me@maxbridgland.com>",
  "homepage": "https://m4cs.github.io/modgrad/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M4cs/modgrad.git"
  },
  "bugs": {
    "url": "https://github.com/M4cs/modgrad/issues"
  },
  "keywords": [
    "react",
    "gradient",
    "mesh-gradient",
    "background",
    "noise",
    "grain",
    "aurora",
    "blur"
  ],
  "scripts": {
    "dev": "bun --hot server.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:demo": "rm -rf dist-demo && bun build ./demo/index.html --outdir ./dist-demo --minify",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5"
  }
}
